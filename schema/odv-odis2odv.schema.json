{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/ns/odv/schema/odv-odis2odv.schema.json",
  "title": "ODIS JSON-LD (schema.org only) for ODV Generic Spreadsheet column mapping",
  "type": "object",
  "required": [
    "@context",
    "@type",
    "@id",
    "identifier",
    "name",
    "distribution",
    "variableMeasured"
  ],
  "properties": {
    "@context": {
      "description": "JSON-LD context. Typically schema.org as @vocab.",
      "oneOf": [
        {
          "type": "object"
        },
        {
          "type": "array"
        },
        {
          "type": "string"
        }
      ]
    },
    "@type": {
      "description": "JSON-LD type. For this profile it MUST include Dataset.",
      "oneOf": [
        {
          "const": "Dataset"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          },
          "contains": {
            "const": "Dataset"
          }
        }
      ]
    },
    "@id": {
      "description": "Stable identifier for the JSON-LD resource (ideally an HTTP URL).",
      "type": "string",
      "minLength": 1
    },
    "identifier": {
      "description": "Human-facing landing page URL for the dataset.",
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "license": {
      "type": "string"
    },
    "keywords": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      ]
    },
    "distribution": {
      "description": "Where the source data can be downloaded from. Converters use contentUrl.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/DataDownload"
      }
    },
    "additionalProperty": {
      "description": "Dataset-level ODV collection metadata (DataField, DataType) and conversion hints (primary variable, separator, fill value).",
      "type": "array",
      "items": {
        "$ref": "#/$defs/DatasetAdditionalProperty"
      }
    },
    "variableMeasured": {
      "description": "Column mapping list. Each item describes one source column and its target output column.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ColumnMapping"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "DataDownload": {
      "type": "object",
      "required": [
        "@type",
        "contentUrl"
      ],
      "properties": {
        "@type": {
          "oneOf": [
            {
              "const": "DataDownload"
            },
            {
              "const": "MediaObject"
            }
          ]
        },
        "contentUrl": {
          "description": "Download location of the provider data file (HTTP(S) URL in production; file:// for local testing).",
          "type": "string",
          "minLength": 1
        },
        "encodingFormat": {
          "description": "MIME type or format hint (e.g. text/csv, text/tab-separated-values).",
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "sha256": {
          "description": "Optional checksum (non-standard schema.org; tolerated).",
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "DatasetAdditionalProperty": {
      "description": "Dataset-level ODV collection metadata and conversion hints expressed as schema.org PropertyValue.",
      "type": "object",
      "required": [
        "@type",
        "name",
        "value"
      ],
      "properties": {
        "@type": {
          "const": "PropertyValue"
        },
        "name": {
          "type": "string",
          "enum": [
            "DataField",
            "DataType",
            "primaryVariableTargetColumn",
            "columnSeparator",
            "fillValue"
          ]
        },
        "value": {
          "description": "Any literal value; converters interpret based on 'name'.",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "const": "DataField"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "enum": [
                  "Ocean",
                  "Atmosphere",
                  "Land"
                ]
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "DataType"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "enum": [
                  "Profiles",
                  "TimeSeries",
                  "Trajectories"
                ]
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "primaryVariableTargetColumn"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "columnSeparator"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string"
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "fillValue"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "oneOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "number"
                  },
                  {
                    "type": "boolean"
                  },
                  {
                    "type": "null"
                  }
                ]
              }
            },
            "required": [
              "value"
            ]
          }
        }
      ]
    },
    "ColumnMapping": {
      "description": "One mapping item for one source column. Data and metadata columns map to an ODV target column. Auxiliary columns such as quality flags and errors may instead refer to a related measured column.",
      "type": "object",
      "required": [
        "@type",
        "name",
        "additionalProperty"
      ],
      "properties": {
        "@type": {
          "const": "PropertyValue"
        },
        "name": {
          "description": "Exact header/name of the source column.",
          "type": "string",
          "minLength": 1
        },
        "description": {
          "description": "Optional schema.org description of the measured variable. Use this field for human-readable parameter definitions, explanations, method notes, or provider comments. This is the preferred place for variable descriptions instead of creating custom additionalProperty entries such as 'comment'.",
          "type": "string"
        },
        "additionalProperty": {
          "description": "Per-column mapping metadata. Columns with role 'data' or 'meta' require targetColumn. Auxiliary columns with role 'quality' or 'error' require relatedColumn and do not require targetColumn.",
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/ColumnAdditionalProperty"
          },
          "allOf": [
            {
              "if": {
                "contains": {
                  "type": "object",
                  "required": [
                    "@type",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "@type": {
                      "const": "PropertyValue"
                    },
                    "name": {
                      "const": "role"
                    },
                    "value": {
                      "enum": [
                        "data",
                        "meta"
                      ]
                    }
                  }
                }
              },
              "then": {
                "contains": {
                  "type": "object",
                  "required": [
                    "@type",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "@type": {
                      "const": "PropertyValue"
                    },
                    "name": {
                      "const": "targetColumn"
                    },
                    "value": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            },
            {
              "if": {
                "contains": {
                  "type": "object",
                  "required": [
                    "@type",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "@type": {
                      "const": "PropertyValue"
                    },
                    "name": {
                      "const": "role"
                    },
                    "value": {
                      "enum": [
                        "quality",
                        "error"
                      ]
                    }
                  }
                }
              },
              "then": {
                "contains": {
                  "type": "object",
                  "required": [
                    "@type",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "@type": {
                      "const": "PropertyValue"
                    },
                    "name": {
                      "const": "relatedColumn"
                    },
                    "value": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            },
            {
              "if": {
                "not": {
                  "contains": {
                    "type": "object",
                    "required": [
                      "@type",
                      "name",
                      "value"
                    ],
                    "properties": {
                      "@type": {
                        "const": "PropertyValue"
                      },
                      "name": {
                        "const": "role"
                      }
                    }
                  }
                }
              },
              "then": {
                "contains": {
                  "type": "object",
                  "required": [
                    "@type",
                    "name",
                    "value"
                  ],
                  "properties": {
                    "@type": {
                      "const": "PropertyValue"
                    },
                    "name": {
                      "const": "targetColumn"
                    },
                    "value": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            }
          ]
        },
        "propertyID": {
          "description": "Optional schema.org propertyID for a persistent semantic identifier of the measured variable or property. Prefer resolvable vocabulary URIs, for example NERC P01 URIs. Do not use this field for free-text comments; use description for human-readable explanations.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "ColumnAdditionalProperty": {
      "description": "Per-column metadata expressed as schema.org PropertyValue. Use native PropertyValue.propertyID for persistent semantic identifiers such as NERC P01 URIs.",
      "type": "object",
      "required": [
        "@type",
        "name",
        "value"
      ],
      "properties": {
        "@type": {
          "const": "PropertyValue"
        },
        "name": {
          "type": "string",
          "enum": [
            "targetColumn",
            "dataType",
            "role",
            "qualityFlagScheme",
            "relatedColumn"
          ]
        },
        "value": {}
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "name": {
                "const": "targetColumn"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "dataType"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "enum": [
                  "Text",
                  "Number",
                  "DateTime"
                ]
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "role"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "enum": [
                  "meta",
                  "data",
                  "quality",
                  "error"
                ]
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "qualityFlagScheme"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "type": "string",
                "enum": [
                  "ODV",
                  "GTSPP",
                  "ARGO",
                  "SEADATANET",
                  "ESEAS",
                  "WOD",
                  "WODSTATION",
                  "WOCEBOTTLE",
                  "WOCECTD",
                  "WOCESAMPLE",
                  "QARTOD",
                  "BODC",
                  "PANGAEA",
                  "SMHI",
                  "OCEANSITES",
                  "IODE"
                ],
                "description": "ODV quality flag set name (QFSetName) defining the interpretation of quality flag values."
              }
            },
            "required": [
              "value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "name": {
                "const": "relatedColumn"
              }
            },
            "required": [
              "name"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "description": "Exact source column name of the measured variable to which this auxiliary column belongs. Used for quality flags, errors, standard deviations, and similar auxiliary variables.",
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "value"
            ]
          }
        }
      ],
      "additionalProperties": true
    }
  }
}
