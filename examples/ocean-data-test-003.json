    {
      "@type": "DataDownload",
      "name": "ocean-data-test-003.txt",
      "description": "Small tab-separated tutorial source dataset for ODIS2ODV.",
      "encodingFormat": "text/tab-separated-values",
      "contentUrl": "https://example.org/odis2odv/dataset/ocean-data-test-003.txt"
    }
  ],
