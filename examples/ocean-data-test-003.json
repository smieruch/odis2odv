  "url": "https://example.org/odis2odv/dataset/ocean-data-test-003",
  "name": "ODIS2ODV example profile dataset",
  "description": "Small tutorial dataset demonstrating how schema.org JSON-LD can describe the deterministic conversion of a tab-separated ocean profile table into an ODV Generic Spreadsheet. The example includes metadata columns, measured data columns, one quality flag column, and one error/standard-deviation column.",
  "keywords": [
    "ODIS2ODV",
    "ODV-compatible",
    "schema.org",
    "JSON-LD",
    "ocean profile",
    "tutorial"
  ],
  "license": "https://creativecommons.org/licenses/by/4.0/",
